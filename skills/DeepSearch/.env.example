# DeepSearch Skill 凭证模板
# 复制为 .env 填入真实值即可使用
# 优先级: 环境变量 > .env

# === GROK2API (LLM 搜索规划 + Grok 搜索) ===
# GROK2API_API_KEY: your-api-key-here
# GROK2API_BASE_URL: https://api.your-host.com/v1
# GROK2API_MODEL: grok-4.20-beta

# === Tavily (结构化搜索/extract/map - 核心) ===
# TAVILY_BASE_URL: https://api.tavily.com
# TAVILY_API_KEY: your-tavily-key-here

# === FireCrawl (web_fetch 降级 - 可选) ===
# FIRECRAWL_BASE_URL: https://api.firecrawl.dev/v2
# FIRECRAWL_API_KEY: your-firecrawl-key-here

# === GrokSearch deployed HTTP gateway (DeepSearch replacement) ===
# GROKSEARCH_URL: https://search.198707.xyz
# GROKSEARCH_BEARER_TOKEN: your-groksearch-gateway-bearer-token
# Optional alias: GROKSEARCH_TOKEN: your-groksearch-gateway-bearer-token
# Optional request timeout seconds: GROKSEARCH_TIMEOUT: 180
