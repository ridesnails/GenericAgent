# AxonHub skill — portable credentials (copy to .env or export in shell)
# Secrets are NOT bundled with the script. Fill these on each host.

# Instance base URL (override only when targeting a different instance)
AXONHUB_URL=https://api.198707.xyz

# admin link (manage channels / models / status) — owner email + password
AXONHUB_ADMIN_USER=
AXONHUB_ADMIN_PASS=

# service link (downstream LLM API key lifecycle only) — ah-... key
AXONHUB_SERVICE_ACCOUNT_KEY=

# Optional: GenericAgent host keychain dir (fallback when env vars unset)
# GA_MEMORY_DIR=/Users/qing/code/GenericAgent/memory
